<div class="page">
  <header class="header">
    <div class="container">
      <a href="/" class="logo">My App</a>
      <nav class="main-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="<%= profile_path %>" class="nav-link"><%= user_name %></a>
      </nav>
      <div class="user-menu">
        <span class="greeting">Hello, <%= user_name %></span>
        <img src="<%= avatar_url %>" alt="<%= user_name %>" class="avatar" />
      </div>
    </div>
  </header>

  <main class="main">
    <section class="hero">
      <div class="container">
        <h1><%= page_title %></h1>
        <p class="subtitle"><%= page_subtitle %></p>
        <div class="hero-actions">
          <a href="<%= signup_path %>" class="btn btn-primary btn-lg">Get Started</a>
          <a href="<%= demo_path %>" class="btn btn-outline btn-lg">Watch Demo</a>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <h2 class="section-title">Why choose us?</h2>
        <div class="grid grid-cols-3 gap-6">
          <div class="feature-card">
            <img src="http://example.com/speed.svg" alt="Fast" class="feature-icon" />
            <h3>Lightning Fast</h3>
            <p>Our platform is optimized for speed with sub-millisecond response times.</p>
            <a href="/features/speed" class="feature-link">Learn more →</a>
          </div>
          <div class="feature-card">
            <img src="http://example.com/secure.svg" alt="Secure" class="feature-icon" />
            <h3>Enterprise Security</h3>
            <p>Bank-grade encryption and security protocols protect your data.</p>
            <a href="/features/security" class="feature-link">Learn more →</a>
          </div>
          <div class="feature-card">
            <img src="http://example.com/scale.svg" alt="Scalable" class="feature-icon" />
            <h3>Infinitely Scalable</h3>
            <p>From startup to enterprise, our infrastructure grows with you.</p>
            <a href="/features/scale" class="feature-link">Learn more →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container text-center">
        <h2>Ready to get started?</h2>
        <p class="cta-text">Join <%= user_count %> happy customers today.</p>
        <a href="<%= trial_path %>" class="btn btn-primary btn-xl">Start Free Trial</a>
        <p class="cta-note">No credit card required. 14-day free trial.</p>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/features">Features</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/changelog">Changelog</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/careers">Careers</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/terms">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= current_year %> My App. All rights reserved.</p>
      </div>
    </div>
  </footer>
</div>
