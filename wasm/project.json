{
  "name": "wasm",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "wasm",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "make all",
        "cwd": "wasm"
      },
      "inputs": ["{projectRoot}/**/*", "{workspaceRoot}/src/**/*", "{workspaceRoot}/include/**/*"],
      "outputs": [
        "{projectRoot}/obj",
        "{workspaceRoot}/javascript/packages/browser/build",
        "{workspaceRoot}/javascript/packages/node-wasm/build"
      ],
      "dependsOn": ["templates:generate"]
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make clean",
        "cwd": "wasm"
      }
    }
  },
  "tags": ["wasm", "native"]
}
