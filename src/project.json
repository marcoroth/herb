{
  "name": "libherb",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "commands": [
          "bundle install",
          "make templates prism build/libherb.a"
        ],
      },
      "inputs": ["{projectRoot}/**/*", "{workspaceRoot}/include/**/*"],
      "outputs": ["{workspaceRoot}/build/libherb.a"],
      "dependsOn": ["templates:generate", "prism:build"]
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "make clean"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "make test",
          "./run_herb_tests"
        ],
        "parallel": false
      },
      "dependsOn": ["libherb:build"]
    }
  },
  "tags": ["native", "c", "library"]
}
